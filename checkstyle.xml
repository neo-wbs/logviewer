<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">

    <!-- Dateien müssen mit Zeilenumbruch enden -->
    <module name="NewlineAtEndOfFile"/>

    <!-- Keine Tabs, nur Spaces -->
    <module name="FileTabCharacter"/>

    <module name="TreeWalker">

        <!-- Imports -->
        <module name="UnusedImports"/>         <!-- keine ungenutzten Imports -->
        <module name="IllegalImport"/>         <!-- keine sun.* Imports -->

        <!-- Benennung -->
        <!-- <module name="TypeName"/>              Klassen: UpperCamelCase -->
        <!-- <module name="MethodName"/>            Methoden: lowerCamelCase -->
        <!-- <module name="LocalVariableName"/>     Variablen: lowerCamelCase -->
        <!-- <module name="ConstantName"/>          Konstanten: UPPER_SNAKE_CASE -->

        <!-- Klammern -->
        <module name="NeedBraces"/>            <!-- if/for/while immer mit {} -->
        <module name="LeftCurly"/>             <!-- { auf gleicher Zeile -->

        <!-- Leerzeichen -->
        <module name="WhitespaceAround"/>      <!-- Spaces um Operatoren -->
        <module name="NoWhitespaceAfter"/>     <!-- kein Space nach ! ~ -->

        <!-- Komplexität -->
        <module name="MethodLength">
            <property name="max" value="60"/>    <!-- max. 60 Zeilen pro Methode -->
        </module>
        <module name="CyclomaticComplexity">
            <property name="max" value="10"/>    <!-- max. Verzweigungstiefe -->
        </module>

        <!-- Sonstiges -->
        <module name="EmptyBlock"/>            <!-- keine leeren {} Blöcke -->
        <module name="SimplifyBooleanReturn"/> <!-- return x==true → return x -->

    </module>
</module>